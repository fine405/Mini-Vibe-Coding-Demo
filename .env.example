# Configure one or more providers locally in .env.local or as encrypted secrets
# in the hosted platform. Empty values keep the provider visible but disabled.
OPENAI_API_KEY=
DASHSCOPE_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=  # Alternative Google key name
# GEMINI_API_KEY=  # Alternative Google key name
MOONSHOT_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# Optional live web research. Keep this server-side; never use a VITE_ prefix.
TAVILY_API_KEY=

# Optional allowlisted model defaults. Omit these to use the built-in defaults.
# OPENAI_DEFAULT_MODEL=openai/gpt-5.4
# QWEN_DEFAULT_MODEL=alibaba-cn/qwen3-coder-plus
# DEEPSEEK_DEFAULT_MODEL=deepseek/deepseek-chat
# ANTHROPIC_DEFAULT_MODEL=anthropic/claude-sonnet-4-6
# GOOGLE_DEFAULT_MODEL=google/gemini-2.5-pro
# MOONSHOT_DEFAULT_MODEL=moonshotai/kimi-k2.7-code
# XAI_DEFAULT_MODEL=xai/grok-build-0.1
# OPENROUTER_DEFAULT_MODEL=openrouter/anthropic/claude-sonnet-4.6
